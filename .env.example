# ─────────────────────────────────────────────────────────────
#  WinBot Environment Variables
#  Copy this file to .env and fill in your values.
#  On Railway, set these directly in the service Variables tab.
#  NEVER commit a real .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Alpaca Paper Trading (free, no real money) ────────────────
# Get at: https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_PAPER_KEY=PK_YOUR_PAPER_KEY_HERE
ALPACA_PAPER_SECRET=YOUR_PAPER_SECRET_HERE

# ── Alpaca Live Trading (real money — leave blank until ready) ─
ALPACA_LIVE_KEY=
ALPACA_LIVE_SECRET=

# ── Anthropic Claude API ──────────────────────────────────────
# Get at: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Trading defaults (can also be changed in the UI) ─────────
TRADING_MODE=paper           # paper | live
TRADING_INTERVAL=5           # minutes between agent cycles
STOP_LOSS_PCT=2.0
MAX_POSITION_SIZE_PCT=10.0
MAX_OPEN_TRADES=5
DAILY_LOSS_LIMIT_PCT=5.0
MIN_CONFIDENCE=0.7

# ── Deployment (Railway + Vercel) ────────────────────────────
# On Railway, mount a volume at /data and set:
DB_PATH=/data/winbot.db
# Your Vercel frontend URL — paste in Railway Variables tab:
FRONTEND_URL=https://your-winbot.vercel.app
